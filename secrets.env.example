# ~/.config/secrets/env — Machine-local secrets, sourced by shell init on every session.
#
# SETUP (required on every machine):
#   1. mkdir -p ~/.config/secrets
#   2. cp ~/.nix-config/secrets.env.example ~/.config/secrets/env
#   3. Fill in your values below
#
# Nix manages CLAUDE_PROFILE and other profile vars automatically.
# This file is for secrets that cannot be committed to any repo.
# Any program (Claude Code, Copilot, CLI tools) can read these by sourcing this file.
#
# DO NOT commit ~/.config/secrets/env — it is gitignored globally by Nix.

# Obsidian Local REST API key (Obsidian → Settings → Local REST API)
export OBSIDIAN_API_KEY=""

# GitHub personal access token (Settings → Developer settings → Personal access tokens)
# Classic token with repo + read:org scopes.
export GITHUB_PERSONAL_ACCESS_TOKEN=""

# GitLab personal access token — api, read_api scopes
export GITLAB_ACCESS_TOKEN=""
# Set to false if corporate CA causes SSL errors
export GITLAB_VERIFY_SSL="true"

# Jira personal access token
export JIRA_PAT=""
